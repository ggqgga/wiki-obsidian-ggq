{
	"schemaVersion": "0.1.0",
	"name": "wiki sns",
	"behavior": "create",
	"noteContentFormat": "{{content}}",
	"properties": [
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "updated",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "tags",
			"value": "sns",
			"type": "multitext"
		},
		{
			"name": "author",
			"value": "{{author}}",
			"type": "text"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "domain",
			"value": "{{domain}}",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		}
	],
	"triggers": [
		"https://x.com/*",
		"https://twitter.com/*",
		"https://www.linkedin.com/*",
		"https://www.reddit.com/*",
		"https://www.threads.net/*",
		"https://mastodon.social/*",
		"https://bsky.app/*",
		"https://www.facebook.com/*",
		"https://www.instagram.com/*"
	],
	"noteNameFormat": "{{date|date:\"YYYY-MM-DD\"}}-{{title|safe_name|trim}}",
	"path": "raw/sources"
}
