{
	"schemaVersion": "0.1.0",
	"name": "wiki book",
	"behavior": "create",
	"noteContentFormat": "{{content}}",
	"properties": [
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "updated",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "tags",
			"value": "book",
			"type": "multitext"
		},
		{
			"name": "author",
			"value": "{{author}}",
			"type": "text"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "domain",
			"value": "{{domain}}",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		}
	],
	"triggers": [
		"https://www.goodreads.com/*",
		"https://books.google.com/*",
		"https://ridibooks.com/*",
		"https://product.kyobobook.co.kr/*",
		"https://www.yes24.com/*",
		"https://www.aladin.co.kr/*",
		"https://www.millie.co.kr/*",
		"https://book.naver.com/*"
	],
	"noteNameFormat": "{{date|date:\"YYYY-MM-DD\"}}-{{title|safe_name|trim}}",
	"path": "raw/sources"
}
