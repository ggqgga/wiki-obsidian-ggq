{
	"schemaVersion": "0.1.0",
	"name": "wiki article",
	"behavior": "create",
	"noteContentFormat": "{{content}}",
	"properties": [
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "updated",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "tags",
			"value": "article",
			"type": "multitext"
		},
		{
			"name": "author",
			"value": "{{author}}",
			"type": "text"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "domain",
			"value": "{{domain}}",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		}
	],
	"triggers": [
		"https://medium.com/*",
		"https://*.substack.com/*",
		"https://blog.*",
		"https://brunch.co.kr/*",
		"https://velog.io/*",
		"https://*.tistory.com/*",
		"https://blog.naver.com/*",
		"https://m.blog.naver.com/*",
		"https://dev.to/*",
		"https://news.hada.io/*",
		"https://yozm.wishket.com/*",
		"https://techcrunch.com/*",
		"https://www.wired.com/*",
		"https://arstechnica.com/*",
		"https://news.ycombinator.com/*",
		"https://www.theverge.com/*"
	],
	"noteNameFormat": "{{date|date:\"YYYY-MM-DD\"}}-{{title|safe_name|trim}}",
	"path": "raw/sources"
}
